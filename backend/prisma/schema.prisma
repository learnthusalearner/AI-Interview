generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InterviewSession {
  id                    String            @id @default(uuid())
  candidateName         String
  candidateEmail        String?
  applicationStatus     ApplicationStatus @default(PENDING)
  status                SessionStatus     @default(IN_PROGRESS)
  overallRecommendation String?
  totalScore            Float?            @default(0.0)
  cheatCount            Int               @default(0)
  evaluationData        Json?
  feedback              String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  messages              Message[]
}

model Message {
  id                 String           @id @default(uuid())
  interviewSessionId String
  interviewSession   InterviewSession @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
  role               Role             // "system", "user", "assistant"
  content            String
  createdAt          DateTime         @default(now())

  // Per-question micro-evaluation scores for candidate answers
  clarity            Int?
  warmth             Int?
  simplicity         Int?
  patience           Int?
  fluency            Int?
  engagement         Int?
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum Role {
  system
  user
  assistant
}
